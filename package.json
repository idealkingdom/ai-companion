{
  "name": "kdaina",
  "displayName": "kdAina",
  "publisher": "idealkingdom",
  "description": "The Autonomous AI Companion for Builders",
  "version": "0.0.42",
  "icon": "resources/logo_128.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/idealkingdom/kdaina.git"
  },
  "engines": {
    "vscode": "^1.101.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "configuration": {
      "title": "kdAina Settings",
      "properties": {
        "kdaina.modelProvider": {
          "type": "string",
          "default": "OpenAI",
          "enum": [
            "OpenAI",
            "Gemini",
            "Anthropic",
            "Mistral",
            "DeepSeek"
          ],
          "description": "API endpoint for the AI model"
        },
        "kdaina.accessToken": {
          "type": "string",
          "default": "",
          "description": "Access token for authentication",
          "markdownDescription": "Access token (e.g., Bearer token for OpenAI or similar services)",
          "password": true
        },
        "kdaina.temperature": {
          "type": "number",
          "default": 1,
          "minimum": 0,
          "maximum": 2,
          "description": "Sampling temperature (0 = deterministic, 2 = more random)"
        },
        "kdaina.disableSslVerification": {
          "type": "boolean",
          "default": false,
          "description": "Bypass SSL certificate validation (useful for corporate VPNs or custom proxy endpoints)",
          "markdownDescription": "Bypass SSL certificate validation (useful for corporate VPNs or custom proxy endpoints)"
        }
      }
    },
    "commands": [
      {
        "command": "kdaina.loadHistory",
        "category": "kdAina",
        "title": "Open History",
        "icon": "$(history)"
      },
      {
        "command": "kdaina.resetChat",
        "category": "kdAina",
        "title": "New Chat",
        "icon": "$(plus)"
      },
      {
        "command": "kdaina.openSettings",
        "category": "kdAina",
        "title": "Settings",
        "icon": "$(settings-gear)"
      },
      {
        "command": "kdaina.prevDiff",
        "category": "kdAina",
        "title": "Previous File",
        "icon": "$(chevron-left)"
      },
      {
        "command": "kdaina.nextDiff",
        "category": "kdAina",
        "title": "Next File",
        "icon": "$(chevron-right)"
      },
      {
        "command": "kdaina.acceptCurrent",
        "category": "kdAina",
        "title": "Accept",
        "icon": "$(check)"
      },
      {
        "command": "kdaina.rejectCurrent",
        "category": "kdAina",
        "title": "Reject",
        "icon": "$(x)"
      },
      {
        "command": "kdaina.acceptAll",
        "category": "kdAina",
        "title": "Accept All",
        "icon": "$(check-all)"
      },
      {
        "command": "kdaina.rejectAll",
        "category": "kdAina",
        "title": "Reject All",
        "icon": "$(clear-all)"
      },
      {
        "command": "kdaina.togglePopup",
        "category": "kdAina",
        "title": "Detach Chat",
        "icon": "$(link-external)"
      },
      {
        "command": "kdaina.openAgentHub",
        "category": "kdAina",
        "title": "Agent Hub",
        "icon": "$(database)"
      },
      {
        "command": "kdaina.resetAllData",
        "category": "kdAina",
        "title": "Reset All Data (Dev)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "kdaina",
          "title": "kdAina",
          "icon": "resources/logo_128.png"
        }
      ]
    },
    "views": {
      "kdaina": [
        {
          "type": "webview",
          "id": "kdaina",
          "name": "Chat",
          "icon": "resources/logo_128.png"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "kdaina.togglePopup",
          "when": "view == kdaina",
          "group": "navigation@0"
        },
        {
          "command": "kdaina.resetChat",
          "when": "view == kdaina",
          "group": "navigation@1"
        },
        {
          "command": "kdaina.loadHistory",
          "when": "view == kdaina",
          "group": "navigation"
        },
        {
          "command": "kdaina.openSettings",
          "when": "view == kdaina",
          "group": "navigation"
        },
        {
          "command": "kdaina.openAgentHub",
          "when": "view == kdaina",
          "group": "navigation"
        }
      ],
      "editor/title": [
        {
          "command": "kdaina.prevDiff",
          "when": "kdaina.reviewPending",
          "group": "navigation@1"
        },
        {
          "command": "kdaina.nextDiff",
          "when": "kdaina.reviewPending",
          "group": "navigation@2"
        },
        {
          "command": "kdaina.acceptCurrent",
          "when": "kdaina.reviewPending",
          "group": "navigation@3"
        },
        {
          "command": "kdaina.rejectCurrent",
          "when": "kdaina.reviewPending",
          "group": "navigation@4"
        },
        {
          "command": "kdaina.acceptAll",
          "when": "kdaina.reviewPending",
          "group": "navigation@5"
        },
        {
          "command": "kdaina.rejectAll",
          "when": "kdaina.reviewPending",
          "group": "navigation@6"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/diff": "^7.0.2",
    "@types/mocha": "^10.0.10",
    "@types/node": "20.x",
    "@types/vscode": "^1.101.0",
    "@typescript-eslint/eslint-plugin": "^8.31.1",
    "@typescript-eslint/parser": "^8.31.1",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.25.1",
    "ts-loader": "^9.5.2",
    "typescript": "^5.8.3",
    "webpack": "^5.99.7",
    "webpack-cli": "^6.0.1"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.76",
    "@ai-sdk/azure": "^3.0.64",
    "@ai-sdk/google": "^3.0.68",
    "@ai-sdk/openai": "^3.0.50",
    "ai": "^6.0.145",
    "pdf-parse": "^1.1.1",
    "zod": "^4.3.6",
    "zod-to-json-schema": "^3.25.2"
  }
}
